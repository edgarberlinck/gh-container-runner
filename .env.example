# GitHub Runner Configuration
RUNNER_URL=https://github.com/your-username/your-repo
RUNNER_TOKEN=your-runner-registration-token

# Note: Runner tokens expire after 1 hour
# Generate a new token at:
# - For repos: https://github.com/USERNAME/REPO/settings/actions/runners/new
# - For orgs:  https://github.com/organizations/ORG/settings/actions/runners/new
